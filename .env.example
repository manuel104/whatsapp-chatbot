# Kapso API Configuration
# Obtén estas credenciales desde tu dashboard de Kapso
KAPSO_API_KEY=your_kapso_api_key_here
KAPSO_WEBHOOK_SECRET=your_webhook_secret_here
KAPSO_API_URL=https://api.kapso.com

# OpenRouter Configuration
# Obtén tu API key desde https://openrouter.ai/keys
# OpenRouter te da acceso a múltiples modelos: GPT-4, Claude, Gemini, Llama, etc.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Google Cloud Configuration
# Service Account JSON key (todo el contenido del archivo JSON en una línea)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# Google Sheets ID (obtén de la URL del spreadsheet)
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive Folder ID (para almacenar facturas)
# 1. Crea una carpeta en Google Drive
# 2. Compártela con el email de tu Service Account (rol: Editor)
# 3. Copia el ID de la URL: https://drive.google.com/drive/folders/[FOLDER_ID]
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# Application Configuration
NODE_ENV=development